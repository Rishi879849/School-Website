# PostgreSQL connection string used by Prisma + the server.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/eduka?schema=public"

# JWT signing keys. The access-token secret is mandatory; if REFRESH_SECRET_KEY
# is omitted, the server falls back to JWT_SECRET_KEY (less safe — generate a
# distinct 32+ char value for prod).
JWT_SECRET_KEY="change-me-to-a-long-random-string"
REFRESH_SECRET_KEY="change-me-to-another-long-random-string"

# Server port (defaults to 3001).
PORT=3001

# Set to "production" in prod to enable Secure + same-origin cookies.
NODE_ENV=development
